# Copy this file to .env and fill in the real values.

# Safety: keep true for the first runs. Set to false only after testing.
DRY_RUN=true
CHECK_INTERVAL=60
MAX_EMAILS_PER_SCAN=20
UNSEEN_ONLY=false
MARK_DRY_RUN_PROCESSED=false

# SMTP sender
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@example.com
SMTP_PASS=your-app-password

# IMAP inbox
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=you@example.com
IMAP_PASS=your-app-password

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# Company profile used by the AI writer
COMPANY_NAME=Your Company
COMPANY_PRODUCTS=LED lighting, solar products
YOUR_NAME=Jane Zhang
YOUR_TITLE=Foreign Trade Manager
REPLY_LANGUAGE=English
