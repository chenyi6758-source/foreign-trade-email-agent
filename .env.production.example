APP_NAME=ExportPilot AI
APP_ENV=production
APP_HOST=127.0.0.1
APP_PORT=8000
APP_BASE_URL=https://your-domain.example.com
DATABASE_URL=sqlite:///./data/app.db

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
SESSION_SECRET=replace-with-a-long-random-session-secret
SESSION_COOKIE_NAME=fta_session
SESSION_TTL_HOURS=12

WEBHOOK_AUTH_ENABLED=true
WEBHOOK_SHARED_SECRET=replace-with-a-long-random-webhook-secret
WEBHOOK_TOKEN_HEADER=X-Webhook-Token
WEBHOOK_SIGNATURE_HEADER=X-Webhook-Signature

LLM_PROVIDER=openai-compatible
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.4
LLM_TIMEOUT_SECONDS=45

COMPANY_NAME=Your Export Company
COMPANY_PRODUCTS=your export products
COMPANY_TONE=professional, warm, concise
SALES_EMAIL=sales@your-domain.example.com

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=sales@your-domain.example.com
SMTP_FROM_NAME=Sales Team

WHATSAPP_PROVIDER=disabled
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=

AUTO_REPLY_ENABLED=true
AUTO_SEND_OUTBOUND=false
REQUIRE_APPROVAL_FOR_COLD_OUTREACH=true
MAX_OUTBOUND_PER_DAY=50
MIN_SECONDS_BETWEEN_OUTBOUND=30
UNSUBSCRIBE_TEXT=Reply STOP to opt out.
UNSUBSCRIBE_ENABLED=true
UNSUBSCRIBE_SECRET=replace-with-a-long-random-unsubscribe-secret
UNSUBSCRIBE_PATH=/unsubscribe

INTEL_FEEDS=
TARGET_MARKETS=United States, Germany, United Kingdom
TARGET_KEYWORDS=importer, distributor, sourcing, procurement, RFQ, tender, buyer
